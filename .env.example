# Mnemo environment variables.
# Copy to .env for local dev, or set in Netlify UI for production.

# Database — local dev uses a file; Turso uses a libsql:// URL.
DATABASE_URL="file:./dev.db"

# Turso auth token — leave empty for local dev; set when using Turso.
TURSO_AUTH_TOKEN=""

# API key for authentication — required in production. If unset in development,
# auth is skipped (startup warning logged). In production with NODE_ENV=production
# and no key, all requests return 503.
MNEMO_API_KEY=""

# Optional: for semantic embeddings. Left unset, /api/search and export `q=`
# fall back to tokenized keyword scoring (Tier 1).
OPENAI_API_KEY=""
EMBEDDINGS_ENABLED="false" # auto-enabled when OPENAI_API_KEY is present

# Tier 3 — override the base URL (default https://mnemo.joshstrohm.me).
# MNEMO_BASE_URL="https://mnemo.joshstrohm.me"

# Tier 3 — webhook delivery on mutations. POST to WEBHOOK_URL with body
# {"event":"memory.created"|"memory.updated"|..., "timestamp", "data"}.
# HMAC-SHA256 of the body is sent via X-Mnemo-Signature when WEBHOOK_SECRET
# is set; 3× retry with backoff. Both must be set together to enable.
# WEBHOOK_URL=""
# WEBHOOK_SECRET=""

# Tier 3 — in-memory per-IP sliding-window rate limit, requests/minute.
# Sliding window. Default 100. Per-Netlify-instance only.
# RATE_LIMIT_RPM="100"

# Tier 3 — optional Cohere rerank on top of hybrid search. Requires
# RERANK_ENABLED=true plus a COHERE_API_KEY. Falls back to a local tag/title
# overlap boost when unset (still better than raw cosine alone).
# COHERE_API_KEY=""
# RERANK_ENABLED="false"
