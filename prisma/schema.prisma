generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  color            String?
  icon             String?
  defaultImportance Float   @default(0.5)
  isArchived       Boolean  @default(false)
  // Tier 3 — per-project export behaviour
  exportTemplate   String?  // markdown | hermes-txt | json
  maxExportChars   Int?
  includeGlobal    Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  memories         Memory[]

  @@index([isArchived])
}

model Memory {
  id               String    @id @default(cuid())
  type             String
  title            String
  content          String
  tags             String
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  importance       Float     @default(0.5)
  expiresAt        DateTime?
  lastAccessedAt   DateTime?
  source           String?
  sourceSessionId  String?
  sourceMessageId  String?
  createdBy        String?
  sourceUrl        String?
  relatedIds       String    @default("[]")
  deletedAt        DateTime?
  embedding        String?
  embeddingModel   String?
  isPinned         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  versions         MemoryVersion[]

  @@index([projectId])
  @@index([type])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([isPinned])
  @@index([sourceSessionId])
}

model MemoryVersion {
  id          String   @id @default(cuid())
  memoryId    String
  memory      Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  content     String
  tags        String
  type        String
  importance  Float
  projectId   String?
  source      String?
  createdAt   DateTime @default(now())

  @@unique([memoryId, version])
  @@index([memoryId])
  @@index([memoryId, version])
}

model ApiKey {
  id          String    @id @default(cuid())
  keyHash     String    @unique
  name        String
  scopes      String    @default("[]") // JSON string array e.g. ["memory:read","memory:write","project:read"]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // create | update | delete | soft_delete | restore | search | export | batch_create | batch_delete | import | backup
  memoryId   String?
  projectId  String?
  actorIp    String?
  userAgent  String?
  apiKeyId   String?
  metadata   String?  // JSON blob with extra context
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([memoryId])
  @@index([projectId])
}
